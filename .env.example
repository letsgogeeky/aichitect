# AIchitect — Environment Variables
#
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# The app gracefully falls back to static JSON files when
# Supabase env vars are not set (safe for local dev without a DB).

# ------------------------------------------------------------
# Supabase (required for live data; optional for local dev)
# Find these in: Supabase Dashboard → Project Settings → API
# ------------------------------------------------------------

# Public URL of your Supabase project (also used to derive your project ref)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon (public) key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, NEVER expose to the browser
# Used by: seed script, nightly cron, admin routes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct (non-pooling) connection URL — used by make db-push / db-diff / db-pull
# Find it in: Supabase Dashboard → Project Settings → Database → Connection string → "Direct connection"
POSTGRES_URL_NON_POOLING=postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require

# ------------------------------------------------------------
# Local Postgres (docker-compose db service — no setup needed)
# Used by: make db-push-local, make db-reset-local
# The values below match the db service in docker-compose.yml exactly.
# ------------------------------------------------------------
# DATABASE_URL=postgresql://postgres:postgres@db:5432/aichitect

# ------------------------------------------------------------
# Supabase CLI auth (optional — only needed for supabase link / studio commands)
# Generate at: https://supabase.com/dashboard/account/tokens
# ------------------------------------------------------------
SUPABASE_ACCESS_TOKEN=your-supabase-personal-access-token

# ------------------------------------------------------------
# GitHub (required for nightly health sync — AIC-9)
# Create a fine-grained PAT with public repo read access at:
#   https://github.com/settings/tokens
# ------------------------------------------------------------
GITHUB_TOKEN=your-github-pat

# ------------------------------------------------------------
# Cron security (required when deploying cron routes)
# Any random secret string — used to authenticate Vercel Cron
# calls to /api/cron/* routes.
# ------------------------------------------------------------
CRON_SECRET=your-cron-secret

# ------------------------------------------------------------
# Optional
# ------------------------------------------------------------

# Override the public site URL (used in metadata/OG).
# Defaults to https://aichitect.dev in production.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
